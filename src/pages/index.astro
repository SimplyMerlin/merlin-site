---
import Layout from "../layouts/Layout.astro";
import VideoShowcase from "../components/VideoShowcase.svelte";
import ClientGrid from "../components/ClientGrid.astro";
import AboutMeSection from "../components/AboutMeSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Editor" page="editor" extraClasses="bg-orange-50 text-stone-900">
  <div class="container mx-auto px-2">
    <div class="flex items-center justify-center py-48 max-sm:py-36">
      <div class="flex max-w-2xl flex-col gap-4">
        <h1 class="text-center font-serif text-8xl tracking-tighter max-sm:text-5xl">
          Quite decent edits by <span class="text-brownish">Merlin</span>!
        </h1>
        <p class="text-center text-balance text-2xl text-stone-700 max-sm:text-lg">
          I'm pretty good at video editing, but I'm not too sure what to write
          here. So this is temporary. Unless you see this... then I forgot to
          write something. (oops)
        </p>
      </div>
    </div>

    <h2 class="text-center font-serif text-6xl tracking-tighter max-sm:text-4xl">
      My best works
    </h2>
    <VideoShowcase client:load />
    
    <h2 class="mt-16 text-center font-serif text-6xl tracking-tighter max-sm:text-4xl">
      Clients & Vids
    </h2>
    <ClientGrid />

    <h2 class="mt-16 text-center font-serif text-6xl tracking-tighter max-sm:text-4xl">
      More stuff about me
    </h2>
    <AboutMeSection />
  </div>
  <Footer />
</Layout>
