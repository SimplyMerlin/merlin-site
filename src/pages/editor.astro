---
import BigFact from "../components/BigFact.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Editor" page="editor" extraClasses="bg-orange-50 text-stone-900">
  <main>
    <section class="pt-32">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-2 gap-4 items-center">
          <div>
            <h1 class="text-7xl font-bold tracking-tight">
              I make some <span class="font-extrabold text-stone-950"
                >really</span
              > cool videos.
            </h1>
          </div>
          <div
            class="aspect-square rounded-xl h-80 justify-self-end bg-gray-400"
          >
          </div>
        </div>
      </div>
    </section>
    <section class="pt-24 text-center">
      <div class="grid grid-cols-3 max-w-4xl mx-auto">
        <BigFact header="5+" description="years of experience" />
        <BigFact header="110k+" description="total views" />
        <BigFact header="5k+" description="total likes" />
      </div>
    </section>
    <section class="max-w-6xl mx-auto pt-24">
      <h2 class="text-4xl font-bold">My best edits, by far.</h2>
      <div class="flex flex-row gap-1 mt-4">
        <div
          class="bg-cover bg-center bg-[url('https://img.youtube.com/vi/SLDoah0SoTI/maxresdefault.jpg')] basis-1/4 h-48 transition-all hover:basis-[30%]"
        >
        </div>
        <div class="bg-red-500 basis-1/4 h-48 transition-all hover:basis-[30%]">
        </div>
        <div class="bg-red-500 basis-1/4 h-48 transition-all hover:basis-[30%]">
        </div>
        <div class="bg-red-500 basis-1/4 h-48 transition-all hover:basis-[30%]">
        </div>
      </div>
    </section>
  </main>
</Layout>
